{
  "name": "wasm-tinygo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "prepare:assets": "node ./scripts/fetch-emception-worker.mjs && node ./scripts/build-go-probe.mjs",
    "predev": "npm run prepare:assets",
    "prebuild": "npm run prepare:assets",
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "check": "tsc --noEmit",
    "test:host": "node --test tests/bootstrap-exports.test.ts tests/build-go-probe.test.mjs tests/compile-unit.test.ts tests/emception-files.test.ts tests/fetch-emception-worker.test.mjs tests/lowered-exports.test.ts tests/patch-emception-worker.test.mjs",
    "test:wasi": "node --test --test-concurrency=1 tests/driver-wasi.test.mjs",
    "test:browser": "node --test tests/browser-smoke.test.mjs"
  },
  "devDependencies": {
    "typescript": "~5.9.3",
    "vite": "^8.0.0"
  },
  "dependencies": {
    "@bjorn3/browser_wasi_shim": "^0.4.2",
    "comlink": "^4.4.2"
  }
}
